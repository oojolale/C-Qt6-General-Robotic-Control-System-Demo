import numpy as np

import matplotlib.pyplot as plt

from matplotlib.animation import FuncAnimation

from scipy.signal import convolve2d

class InformationFieldSimulator:

"""模拟信息场在物理-生化背景下的涌现"""

def init(self, size=80):

self.size = size

# 1. 物理背景场：简单的能量/浓度梯度
x, y = np.meshgrid(np.linspace(-1, 1, size), np.linspace(-1, 1, size))
self.physical_field = np.exp(-(x**2 + y**2) / 0.5)  # 中心能量高

# 2. 生化“汤”：随机分布的底物浓度
self.substrate = np.random.rand(size, size) * 0.5

# 3. 信息场（核心）：初始为完全随机的“序列”或“模式”强度
# 值代表某种特定模式的“浓度”或“活性”
self.information_field = np.random.randn(size, size) * 0.1  # 从噪声开始

# 4. 催化剂/模板：能复制和增强信息模式的“特殊分子”
# 其分布与信息场强度相关
self.catalyst = np.zeros((size, size))

# 模拟参数
self.diffusion_rate = 0.1
self.replication_strength = 0.05  # 信息自我复制的强度
self.decay_rate = 0.02
self.coupling_strength = 0.3  # 信息场与物理/生化场的耦合强度

# 用于检测模式形成的滤波器（检测自我复制）
self.pattern_kernel = np.array([[0, 1, 0],
                                [1, -4, 1],
                                [0, 1, 0]]) * 0.2

# 历史记录
self.info_entropy_history = []
self.correlation_history = []

def calculate_mutual_information(self):
"""计算信息场与物理场的互信息（简化版），衡量耦合程度"""
# 将场离散化
info_bins = np.digitize(self.information_field, bins=np.linspace(-1, 1, 10))
phys_bins = np.digitize(self.physical_field, bins=np.linspace(0, 1, 10))

# 计算联合分布和边际分布
joint_hist, _, _ = np.histogram2d(info_bins.flatten(), phys_bins.flatten(), 
                                 bins=(10, 10), density=True)
info_marginal = joint_hist.sum(axis=1)
phys_marginal = joint_hist.sum(axis=0)

# 避免log(0)
joint_hist[joint_hist == 0] = 1e-10
info_marginal[info_marginal == 0] = 1e-10
phys_marginal[phys_marginal == 0] = 1e-10

# 计算互信息
mi = 0
for i in range(10):
    for j in range(10):
        mi += joint_hist[i, j] * np.log(joint_hist[i, j] / 
                                       (info_marginal[i] * phys_marginal[j]))
return max(0, mi)

def update(self):
"""更新一个时间步"""
# 步骤1: 信息扩散（类似分子扩散）
kernel = np.ones((3, 3)) / 9
info_diffused = convolve2d(self.information_field, kernel, mode='same', boundary='wrap')

# 步骤2: 基于物理场的约束——高能区更易发生“反应”
physical_constraint = np.tanh(self.physical_field * 2)  # 将物理场转化为反应概率

# 步骤3: 自我复制/催化反馈（关键！）
# 催化剂浓度与信息场强度正相关
self.catalyst = np.tanh(self.information_field**2) * 0.5

# 催化反应：信息模式在催化剂作用下自我增强
# 这里模拟一个简单的自催化：信息场越强，催化剂越多，复制越强
replication = (self.information_field * self.catalyst * 
             self.replication_strength * physical_constraint)

# 步骤4: 消耗底物来维持信息（简单的“代谢”耦合）
substrate_usage = replication * self.substrate * 0.1
self.substrate -= substrate_usage
self.substrate = np.clip(self.substrate, 0, 1)

# 底物扩散和补充
self.substrate = convolve2d(self.substrate, kernel, mode='same', boundary='wrap')
self.substrate += np.random.rand(self.size, self.size) * 0.01  # 随机补充

# 步骤5: 信息场演化方程
old_info = self.information_field
self.information_field = (
    info_diffused * (1 - self.diffusion_rate) +
    self.information_field * (1 - self.decay_rate) +
    replication -
    substrate_usage * 0.5  # 代谢消耗对信息有轻微破坏
)

# 步骤6: 非线性饱和效应（模拟有限资源）
self.information_field = np.tanh(self.information_field)

# 步骤7: 物理场的缓慢变化（环境变化）
if np.random.rand() < 0.05:
    # 随机扰动物理场
    ix, iy = np.random.randint(0, self.size, 2)
    self.physical_field[ix-5:ix+5, iy-5:iy+5] *= np.random.uniform(0.9, 1.1)
    self.physical_field = np.clip(self.physical_field, 0, 1)

# 记录统计量
info_entropy = -np.sum(self.information_field**2 * np.log(self.information_field**2 + 1e-10))
self.info_entropy_history.append(info_entropy)
self.correlation_history.append(self.calculate_mutual_information())

return old_info, self.information_field

def visualize(self, steps=400):
"""运行并可视化模拟"""
fig, axes = plt.subplots(2, 3, figsize=(15, 10))
plt.subplots_adjust(hspace=0.3, wspace=0.3)

ims = []

def animate(frame):
    for ax in axes.flat:
        ax.clear()
    
    old_info, new_info = self.update()
    
    # 子图1: 物理背景场
    im1 = axes[0, 0].imshow(self.physical_field, cmap='hot', origin='lower')
    axes[0, 0].set_title('物理场 (能量/浓度梯度)')
    axes[0, 0].set_xlabel('X')
    axes[0, 0].set_ylabel('Y')
    plt.colorbar(im1, ax=axes[0, 0], fraction=0.046, pad=0.04)
    
    # 子图2: 生化底物场
    im2 = axes[0, 1].imshow(self.substrate, cmap='Greens', origin='lower')
    axes[0, 1].set_title('生化底物场')
    axes[0, 1].set_xlabel('X')
    axes[0, 1].set_ylabel('Y')
    plt.colorbar(im2, ax=axes[0, 1], fraction=0.046, pad=0.04)
    
    # 子图3: 信息场（当前状态）
    im3 = axes[0, 2].imshow(self.information_field, cmap='RdBu', origin='lower', 
                           vmin=-1, vmax=1)
    axes[0, 2].set_title(f'信息场 (模式强度) - 步数: {frame}')
    axes[0, 2].set_xlabel('X')
    axes[0, 2].set_ylabel('Y')
    plt.colorbar(im3, ax=axes[0, 2], fraction=0.046, pad=0.04)
    
    # 子图4: 催化剂分布
    im4 = axes[1, 0].imshow(self.catalyst, cmap='Purples', origin='lower')
    axes[1, 0].set_title('催化剂分布 (由信息场生成)')
    axes[1, 0].set_xlabel('X')
    axes[1, 0].set_ylabel('Y')
    plt.colorbar(im4, ax=axes[1, 0], fraction=0.046, pad=0.04)
    
    # 子图5: 信息场变化率 (突现的“活性”)
    change = new_info - old_info
    im5 = axes[1, 1].imshow(change, cmap='coolwarm', origin='lower', 
                           vmin=-0.1, vmax=0.1)
    axes[1, 1].set_title('信息场变化率 (自组织活性)')
    axes[1, 1].set_xlabel('X')
    axes[1, 1].set_ylabel('Y')
    plt.colorbar(im5, ax=axes[1, 1], fraction=0.046, pad=0.04)
    
    # 子图6: 统计信息
    ax6 = axes[1, 2]
    if len(self.info_entropy_history) > 10:
        steps_range = range(len(self.info_entropy_history))
        ax6.plot(steps_range, self.info_entropy_history, 'b-', label='信息熵', linewidth=2)
        ax6.set_xlabel('时间步')
        ax6.set_ylabel('信息熵', color='b')
        ax6.tick_params(axis='y', labelcolor='b')
        ax6.set_ylim(bottom=0)
        
        ax6_twin = ax6.twinx()
        ax6_twin.plot(steps_range, self.correlation_history, 'r-', 
                    label='场间互信息', linewidth=2, alpha=0.7)
        ax6_twin.set_ylabel('互信息 (耦合度)', color='r')
        ax6_twin.tick_params(axis='y', labelcolor='r')
        ax6_twin.set_ylim(bottom=0)
        
        # 合并图例
        lines1, labels1 = ax6.get_legend_handles_labels()
        lines2, labels2 = ax6_twin.get_legend_handles_labels()
        ax6.legend(lines1 + lines2, labels1 + labels2, loc='upper left', fontsize=8)
    
    ax6.set_title('系统演化统计')
    ax6.grid(True, alpha=0.3)
    
    return axes.flat

anim = FuncAnimation(fig, animate, frames=steps, interval=50, repeat=False, blit=False)
plt.show()

# 最终分析
print("\n" + "="*60)
print("模拟分析：信息场的涌现")
print("="*60)
final_mi = self.correlation_history[-1] if self.correlation_history else 0
if final_mi > 0.1:
    print("✅ 检测到显著的信息场涌现！")
    print(f"   - 最终互信息（耦合度）: {final_mi:.3f}")
    print(f"   - 信息模式已从噪声中稳定并开始与环境耦合。")
    print("   - 这表明一个初步的、具有自我维持倾向的‘信息回路’可能已形成。")
else:
    print("⏳ 信息场仍处于混沌或未耦合状态。")
    print("   - 这可能意味着模拟条件尚未达到‘临界点’，或需要更强的自催化反馈。")
print("="*60)


